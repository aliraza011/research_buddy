{
  "manifest_version": 3,
  "name": "Research Buddy",
  "version": "0.1.0",
  "short_name": "ResearchBuddy",
  "description": "Monitors arXiv for research aligned with your profile and summarizes findings with a local LLM.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "https://export.arxiv.org/*",
    "https://scholar.google.com/*",
    "http://localhost/*",
    "https://localhost/*"
  ],
  "icons": {
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Research Buddy",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}

